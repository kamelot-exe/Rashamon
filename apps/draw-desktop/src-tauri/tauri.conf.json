{
  "$schema": "https://raw.githubusercontent.com/nicklasxyz/tauri2-schemas/main/tauri2.config.schema.json",
  "productName": "Rashamon Draw",
  "version": "0.0.0",
  "identifier": "com.rashamon.draw",
  "build": {
    "beforeDevCommand": "pnpm vite-dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite-build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Rashamon Draw",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Visible",
        "hiddenTitle": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
