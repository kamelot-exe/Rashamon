{
  "name": "rashamon",
  "private": true,
  "version": "0.0.0",
  "description": "Professional creative software ecosystem. Open source by default. Linux-first.",
  "type": "module",
  "scripts": {
    "dev:draw": "pnpm --filter @rashamon/draw-desktop dev",
    "build:draw": "pnpm --filter @rashamon/draw-desktop build",
    "preview:draw": "pnpm --filter @rashamon/draw-desktop preview",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,scss}\"",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck",
    "tauri:draw": "cd apps/draw-desktop/src-tauri && cargo",
    "clean": "pnpm -r exec -- rm -rf dist node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.5.0"
}
